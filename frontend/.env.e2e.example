E2E_BASE_URL=http://127.0.0.1:3000
E2E_BACKEND_URL=http://127.0.0.1:8000

# Optional protected-flow credentials for manual/local demo environments.
# Do not put real production passwords in this file.
E2E_JOBSEEKER_EMAIL=jobseeker@example.com
E2E_JOBSEEKER_PASSWORD=replace_with_local_password
E2E_RECRUITER_EMAIL=recruiter@example.com
E2E_RECRUITER_PASSWORD=replace_with_local_password
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=replace_with_local_password

# Optional Playwright storage-state JSON files for CAPTCHA/OTP-protected flows.
# Generate these locally with npm.cmd run test:e2e:setup-auth after setting disposable demo credentials.
# The setup opens a headed browser so you can solve CAPTCHA/OTP without weakening security.
E2E_JOBSEEKER_STORAGE_STATE=tests/.auth/jobseeker.json
E2E_RECRUITER_STORAGE_STATE=tests/.auth/recruiter.json
E2E_ADMIN_STORAGE_STATE=tests/.auth/admin.json

# Optional: increase if demo email/OTP delivery is slow.
E2E_AUTH_SETUP_TIMEOUT_MS=180000
